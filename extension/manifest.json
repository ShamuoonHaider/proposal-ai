{
  "manifest_version": 3,
  "name": "Proposal AI — Upwork Assistant",
  "version": "1.0.0",
  "description": "Generate AI-powered proposals directly on Upwork job listings",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.upwork.com/*", "*://localhost/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.upwork.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
